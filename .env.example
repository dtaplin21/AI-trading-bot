# =============================================================================
# Trading AI — Environment Variables (master template)
# =============================================================================
#
# Copy values into:
#   trading-ai-model/backend/.env     ← backend / watcher / API / ML / brokers
#   trading-ai-model/frontend/.env    ← frontend only (Vite: must use VITE_ prefix)
#
# Never commit real secrets. Add .env to .gitignore (already ignored in frontend).
#
# Legend:
#   [FRONTEND]  → trading-ai-model/frontend/.env
#   [BACKEND]   → trading-ai-model/backend/.env
#   [API KEY]   → secret credential from a third-party provider
#   [OPTIONAL]  → safe to leave empty for local dev
# =============================================================================


# =============================================================================
# FRONTEND — React / Vite dashboard
# File: trading-ai-model/frontend/.env
# =============================================================================

# [FRONTEND] Backend API base URL (used by dashboard.js + trades.js)
# Local dev: omit or use "/api" — vite.config.js proxies /api → http://127.0.0.1:8000
# Production: full URL, e.g. https://api.yourdomain.com
VITE_API_URL=/api


# =============================================================================
# BACKEND — Application core
# File: trading-ai-model/backend/.env
# =============================================================================

# --- App & logging [BACKEND] ---
APP_ENV=development
LOG_LEVEL=INFO

# --- FastAPI server [BACKEND] ---
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=false

# --- Database (TimescaleDB / PostgreSQL) [BACKEND] [OPTIONAL] ---
# docker compose -f trading-ai-model/backend/docker-compose.yml up -d
DATABASE_URL=postgresql://trading:trading@localhost:5432/trading_ai

# --- Time-series storage (InfluxDB) [BACKEND] [OPTIONAL] ---
INFLUXDB_URL=
INFLUXDB_TOKEN=
INFLUXDB_ORG=
INFLUXDB_BUCKET=

# --- Market data provider label [BACKEND] [OPTIONAL] ---
# Informational / future adapter routing (e.g. polygon, tradovate, ibkr)
MARKET_DATA_PROVIDER=
DATA_STALE_MINUTES=15


# =============================================================================
# BACKEND — LLM (Anthropic) — news sentiment + audit explanations only
# Never used to place trades.
# =============================================================================

# [BACKEND] Enable LLM calls when ANTHROPIC_API_KEY is set
LLM_ENABLED=false

# [API KEY] Anthropic — https://console.anthropic.com/
# Used by: NewsSentimentService, LLMExplainer, AuditAgent
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_MAX_TOKENS=350


# =============================================================================
# BACKEND — News & economic data API keys
# Used by: agents/news/news_ingestion_service.py
# RSS feeds work without keys; APIs unlock more coverage.
# =============================================================================

# [BACKEND] Master switch for background news agent (api/main.py lifespan)
# Set false for dev to skip startup ingest; toggle on/off from dashboard UI at runtime.
NEWS_ENABLED=true
NEWS_POLLING_INTERVAL_SECONDS=14400
NEWS_POLLING_INTERVAL=14400
NEWS_LOAD_DEFAULT_CALENDAR=false
NEWS_CALENDAR_SYNC_INTERVAL_SECONDS=21600
NEWS_CALENDAR_CATCHUP_MINUTES=30
NEWS_CALENDAR_MAX_TRIGGERS_PER_DAY=50
NEWS_CALENDAR_DAYS_AHEAD=14
NEWS_CALENDAR_TRIGGER_OFFSETS=-15,0,5
NEWS_CALENDAR_ARCHIVE=logs/calendar_schedule.jsonl
NEWS_CALENDAR_TZ=America/New_York

# Watcher reads news from DB (API ingests). Use "local" for standalone watch without API.
WATCHER_NEWS_SOURCE=db
WATCHER_NEWS_REFRESH_SECONDS=60

# [API KEY] Finnhub — https://finnhub.io/
# Used for: market news headlines, economic calendar
FINNHUB_API_KEY=

# [API KEY] Benzinga — https://www.benzinga.com/apis
# Used for: real-time financial news wire
BENZINGA_API_KEY=

# [API KEY] Polygon.io — https://polygon.io/
# Used for: market news; also typical source for live OHLCV / WebSocket (chart watcher live mode)
POLYGON_API_KEY=

# [API KEY] Financial Modeling Prep — https://site.financialmodelingprep.com/
# Used for: news articles, economic calendar events
FMP_API_KEY=

# [API KEY] NewsAPI.org — https://newsapi.org/
# Used for: general financial headlines
NEWSAPI_KEY=

# [API KEY] Marketaux — https://www.marketaux.com/
# Used for: symbol-tagged market news
MARKETAUX_API_KEY=

# [API KEY] Alpha Vantage — https://www.alphavantage.co/
# Used for: news sentiment feed
ALPHA_VANTAGE_KEY=

# [API KEY] FRED (Federal Reserve Economic Data) — https://fred.stlouisfed.org/docs/api/api_key.html
# Used for: macro economic series (public demo key used if empty)
FRED_API_KEY=

# [API KEY] U.S. Energy Information Administration — https://www.eia.gov/opendata/
# Used for: oil / energy inventory and supply data
EIA_API_KEY=


# =============================================================================
# BACKEND — Chart watcher (24/7 bar feed → TradingPipelineSupervisor)
# Started automatically by npm run dev unless DEV_START_WATCHER=false
# Standalone: cd trading-ai-model/backend && python main.py --mode watch
# Production worker (live Polygon bars + pipeline): python main.py --mode worker
# Render: see render.yaml → trading-ai-worker service
# =============================================================================

# Include chart watcher when running npm run dev (default: true)
DEV_START_WATCHER=true

WATCHER_MODE=paper
WATCHER_SYMBOLS=MES,ES,MNQ,NQ,CL,GC,ZB,RTY,EURUSD,GBPUSD,USDJPY,USDCHF,AUDUSD,BTCUSD,ETHUSD,SOLUSD,BNBUSD,XRPUSD,TSLA,NVDA,AAPL,MSFT,AMZN
WATCHER_TIMEFRAMES=1m,5m,15m,1h
WATCHER_REPLAY_START=2025-01-01
WATCHER_REPLAY_END=2025-12-31
WATCHER_REPLAY_SPEED=100
WATCHER_DATA_PATH=data/ohlcv
WATCHER_BAR_INTERVAL=60
WATCHER_LOG_BARS=false
WATCHER_TZ=America/New_York

# Live / worker market-data broker (OHLCV feed — not order execution yet)
# Options: polygon | paper | none
# Worker (--mode worker) defaults to polygon when POLYGON_API_KEY is set, else paper
BROKER=polygon

# Polygon futures ticker overrides (plan-dependent). Examples:
# POLYGON_TICKER_MES=C:MES
# POLYGON_FUTURES_TICKER_MAP={"MES":"C:MES","NQ":"C:NQ"}

# Dashboard / session watchlist (symbol:timeframe pairs)
CHART_WATCHLIST=MES:5m,ES:5m,NQ:5m,MNQ:5m


# =============================================================================
# BACKEND — Brokers & execution platforms
# ENABLED_BROKERS: comma-separated ids matching keys below
# Options: paper, robinhood, webull, alpaca, schwab, tastytrade, ibkr, tradovate, ninjatrader
# =============================================================================

ENABLED_BROKERS=paper
PAPER_TRADING_ENABLED=true

# [BACKEND] Paper / simulation — no API key required
# (uses internal PaperTrader)

# [API KEY] Robinhood — https://robinhood.com/us/en/support/articles/api/
ROBINHOOD_ACCESS_TOKEN=

# [API KEY] Webull Open API — https://developer.webull.com/
WEBULL_APP_KEY=
WEBULL_APP_SECRET=

# [API KEY] Alpaca Markets — https://alpaca.markets/
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_PAPER=true

# [API KEY] Charles Schwab Developer Portal — https://developer.schwab.com/
SCHWAB_APP_KEY=
SCHWAB_APP_SECRET=

# [BACKEND] tastytrade — session credentials (not a single API key)
TASTYTRADE_USERNAME=
TASTYTRADE_PASSWORD=

# [BACKEND] Interactive Brokers — TWS / IB Gateway must be running locally
IBKR_ACCOUNT_ID=
IBKR_HOST=127.0.0.1
IBKR_PORT=7497

# [API KEY] Tradovate — https://tradovate.com/ (CME futures: MES, ES, NQ, etc.)
TRADOVATE_API_KEY=
TRADOVATE_USERNAME=

# [API KEY] NinjaTrader — Continuum / Rithmic license
NINJATRADER_LICENSE_KEY=


# =============================================================================
# BACKEND — Risk engine & account
# =============================================================================

ACCOUNT_SIZE=10000
RISK_KILL_SWITCH=false
RISK_MAX_DAILY_LOSS_PCT=0.02
RISK_MAX_DRAWDOWN_PCT=0.06
RISK_MAX_CONTRACTS=5
RISK_MAX_OPEN_POSITIONS=3
RISK_MIN_RR_RATIO=1.5
RISK_MAX_CONSECUTIVE_LOSSES=4

# Settings.py aliases (legacy / dashboard)
MAX_DAILY_LOSS_PCT=2.0
MAX_DRAWDOWN_PCT=10.0
MAX_POSITIONS=3
DEFAULT_RISK_PER_TRADE_PCT=0.5


# =============================================================================
# BACKEND — Probability gate & trade planning (MCTS / beam / expectimax)
# =============================================================================

PROBABILITY_GATE_P_MIN=0.55
PROBABILITY_GATE_EV_MIN=0.0
PROBABILITY_GATE_SAMPLE_MIN=100
PROBABILITY_GATE_RANK_MIN=65

MCTS_ROLLOUTS=500
MCTS_EXPLORATION=1.414
MCTS_CONFIDENCE_THRESHOLD=0.55
LOSS_AVERSION_MULTIPLIER=2.0
BEAM_WIDTH=4
BEAM_MIN_EV=0.0

# Per-symbol tick value for EV math (optional overrides)
TICK_VALUE_MES=1.25
TICK_VALUE_ES=12.50
TICK_VALUE_NQ=5.00
TICK_VALUE_MNQ=0.50
TICK_VALUE_CL=10.00
TICK_VALUE_GC=10.00
TICK_VALUE_ZB=31.25
TICK_VALUE_ZN=15.625


# =============================================================================
# BACKEND — ML / LightGBM / learning loop
# =============================================================================

MODEL_DIR=./models
PRODUCTION_MODEL_ID=lightgbm_production
LIGHTGBM_MODEL_PATH=ml/models/lightgbm_production.pkl
RETRAIN_SCHEDULE_DAYS=1

LEARNING_MIN_SAMPLES=100
LEARNING_BRIER_IMPROVEMENT=0.01
LEARNING_PAPER_DAYS=5
LEARNING_OUTCOMES_LOG=logs/outcomes.jsonl
LEARNING_TRAINING_ROWS=logs/training_rows.jsonl
# Gate in-process retrains by RETRAIN_SCHEDULE_DAYS (default daily)
LEARNING_RETRAIN_SCHEDULED=true
LEARNING_RETRAIN_WEEKLY=true
LEARNING_RETRAIN_STATE=logs/learning_retrain_state.json

# Compact MCTS / beam search audits (debugging & academic analysis — not full trees)
PLANNER_AUDIT_LOG=logs/planner_audits.jsonl

# [OPTIONAL] MLflow experiment tracking — https://mlflow.org/
MLFLOW_TRACKING_URI=

MIN_PATTERN_SAMPLE_SIZE=300
HARMONIC_RATIO_TOLERANCE_PCT=3.0
ELLIOTT_CONFIDENCE_THRESHOLD=0.60
GANN_RESEARCH_ONLY=true

SIGNAL_LOG_DIR=./logs/signals


# =============================================================================
# Quick reference — which API key belongs to what
# =============================================================================
#
# | Variable              | Provider            | Used for                          |
# |-----------------------|---------------------|-----------------------------------|
# | ANTHROPIC_API_KEY     | Anthropic           | News sentiment, audit text        |
# | FINNHUB_API_KEY       | Finnhub             | News + econ calendar              |
# | BENZINGA_API_KEY      | Benzinga            | News wire                         |
# | POLYGON_API_KEY       | Polygon.io          | News; live market data (future)   |
# | FMP_API_KEY           | Financial Modeling  | News + calendar                   |
# | NEWSAPI_KEY           | NewsAPI.org         | Headlines                         |
# | MARKETAUX_API_KEY     | Marketaux           | Symbol news                       |
# | ALPHA_VANTAGE_KEY     | Alpha Vantage       | News feed                         |
# | FRED_API_KEY          | Federal Reserve     | Macro data                        |
# | EIA_API_KEY           | U.S. EIA            | Energy data                       |
# | ROBINHOOD_ACCESS_TOKEN| Robinhood           | Stock/options execution           |
# | WEBULL_APP_KEY/SECRET | Webull              | Stock/options execution           |
# | ALPACA_API_KEY/SECRET | Alpaca              | Stocks/crypto execution           |
# | SCHWAB_APP_KEY/SECRET | Charles Schwab      | Broker OAuth                      |
# | TASTYTRADE_USER/PASS  | tastytrade          | Options/futures session           |
# | IBKR_*                | Interactive Brokers | TWS/Gateway futures               |
# | TRADOVATE_API_KEY     | Tradovate           | CME futures execution             |
# | NINJATRADER_LICENSE   | NinjaTrader         | Futures bridge                    |
# | DATABASE_URL          | PostgreSQL          | News store, signals (optional)    |
# | INFLUXDB_*            | InfluxDB            | Time-series OHLCV (optional)      |
# | VITE_API_URL          | (your backend URL)  | Frontend → API calls              |
#
# Minimum to run locally (paper mode, synthetic bars):
#   BACKEND: leave API keys empty; WATCHER_MODE=paper
#   FRONTEND: VITE_API_URL=/api
#
# Full dashboard dev stack (API + UI one command):
#   cd trading-ai-model/backend && python main.py --mode dev
#   (or from trading-ai-model: npm run dev)
#
# Recommended for news + LLM:
#   FINNHUB_API_KEY or POLYGON_API_KEY + ANTHROPIC_API_KEY + LLM_ENABLED=true
# =============================================================================
