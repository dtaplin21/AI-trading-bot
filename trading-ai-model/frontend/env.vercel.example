# Copy into Vercel → Project → Settings → Environment Variables
# Root directory must be: trading-ai-model/frontend
#
# Optional if .env.production is committed (Mode A already set there).

# Mode A — browser calls Render directly (set CORS_ORIGINS on Render too)
VITE_API_URL=https://ai-trading-app-m22o.onrender.com

# Mode B — use vercel.json proxy instead; set this and do NOT rely on .env.production
# VITE_API_URL=/api
