# Frontend environment variables (Vite)
#
# Full master template:
#   ../../.env.example   (repo root)
#
# Copy the FRONTEND section from the root file into this file as .env
# Only variables prefixed with VITE_ are exposed to the browser.

# [FRONTEND] Local dev only — copy to .env (see .env.production for production builds)
# Vite dev server proxies /api → http://127.0.0.1:8000
VITE_API_URL=/api

# Production API (Render): https://ai-trading-app-m22o.onrender.com
# — already in .env.production for Vercel builds
# — or set VITE_API_URL in Vercel dashboard (see env.vercel.example)
