# Database (optional)
DATABASE_URL=postgresql://trading:trading@localhost:5432/trading_ai

# Charts the pipeline watches (symbol:timeframe, comma-separated)
CHART_WATCHLIST=MES:5m,ES:5m,NQ:5m,MNQ:5m

# Chart watcher — 24/7 bar feed into TradingPipelineSupervisor
WATCHER_MODE=paper
WATCHER_SYMBOLS=MES,NQ
WATCHER_TIMEFRAMES=1m,5m,15m,1h
WATCHER_REPLAY_START=2025-01-01
WATCHER_REPLAY_END=2025-12-31
WATCHER_REPLAY_SPEED=100
WATCHER_DATA_PATH=data/ohlcv
WATCHER_BAR_INTERVAL=60
WATCHER_LOG_BARS=false

# Trading platforms — comma-separated broker ids to enable for live routing
# Options: paper, robinhood, webull, alpaca, schwab, tastytrade, ibkr, tradovate, ninjatrader
ENABLED_BROKERS=paper

# Robinhood
ROBINHOOD_ACCESS_TOKEN=

# Webull
WEBULL_APP_KEY=
WEBULL_APP_SECRET=

# Alpaca
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_PAPER=true

# Charles Schwab
SCHWAB_APP_KEY=
SCHWAB_APP_SECRET=

# tastytrade
TASTYTRADE_USERNAME=
TASTYTRADE_PASSWORD=

# Interactive Brokers (requires TWS / Gateway running)
IBKR_ACCOUNT_ID=
IBKR_HOST=127.0.0.1
IBKR_PORT=7497

# Tradovate (CME futures)
TRADOVATE_API_KEY=
TRADOVATE_USERNAME=

# NinjaTrader
NINJATRADER_LICENSE_KEY=

# News API keys (optional — enable sources when configured)
FINNHUB_API_KEY=
BENZINGA_API_KEY=
POLYGON_API_KEY=
FMP_API_KEY=
NEWSAPI_KEY=
MARKETAUX_API_KEY=
ALPHA_VANTAGE_KEY=
FRED_API_KEY=
EIA_API_KEY=

# LLM — Anthropic only (news sentiment + audit explanations; never executes trades)
LLM_ENABLED=false
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_MAX_TOKENS=350
