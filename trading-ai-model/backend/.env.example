# Trading AI Model — backend environment template
# Copy to .env and fill in values: cp .env.example .env

# ── Database (optional) ─────────────────────────────────────────────────────
# Required for cross-process kill switch, OHLCV storage, level intelligence.
DATABASE_URL=postgresql://trading:trading@localhost:5432/trading_ai

# ── Kill switch ─────────────────────────────────────────────────────────────
# RISK_KILL_SWITCH — startup default only (false = trading allowed on boot).
# Runtime toggles via dashboard PUT /risk/kill-switch or MCP set_kill_switch
# persist to Postgres runtime_controls and override this env var in-process.
# Watcher subprocess reads Postgres every ~2s (KILL_SWITCH_CACHE_TTL_SEC).
RISK_KILL_SWITCH=false
# KILL_SWITCH_CACHE_TTL_SEC=2

# ── Chart watcher ───────────────────────────────────────────────────────────
WATCHER_MODE=paper
WATCHER_SYMBOLS=MES,ES,NQ
WATCHER_TIMEFRAMES=1m,5m,15m,1h
WATCHER_BAR_INTERVAL=60

# ── Risk limits ─────────────────────────────────────────────────────────────
RISK_MAX_DAILY_LOSS_PCT=2.0
RISK_MAX_DRAWDOWN_PCT=10.0
RISK_MAX_OPEN_POSITIONS=3
RISK_MAX_CONSECUTIVE_LOSSES=4
RISK_MAX_CONTRACTS=5
RISK_MIN_RR_RATIO=1.5

# ── Paper vs live ───────────────────────────────────────────────────────────
PAPER_TRADING_ENABLED=true
ENABLED_BROKERS=paper

# ── News ────────────────────────────────────────────────────────────────────
NEWS_ENABLED=true
WATCHER_NEWS_SOURCE=db

# ── LLM (optional) ──────────────────────────────────────────────────────────
LLM_ENABLED=false
# ANTHROPIC_API_KEY=

# ── API keys (optional) ─────────────────────────────────────────────────────
# POLYGON_API_KEY=
# FRED_API_KEY=
# OANDA_API_KEY=
# COINBASE_API_KEY=
# COINBASE_API_SECRET=
