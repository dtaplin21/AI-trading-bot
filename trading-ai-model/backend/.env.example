# Database (optional)
DATABASE_URL=postgresql://trading:trading@localhost:5432/trading_ai

# Charts the pipeline watches (symbol:timeframe, comma-separated)
CHART_WATCHLIST=MES:5m,ES:5m,NQ:5m,MNQ:5m

# Trading platforms — comma-separated broker ids to enable for live routing
# Options: paper, robinhood, webull, alpaca, schwab, tastytrade, ibkr, tradovate, ninjatrader
ENABLED_BROKERS=paper

# Robinhood
ROBINHOOD_ACCESS_TOKEN=

# Webull
WEBULL_APP_KEY=
WEBULL_APP_SECRET=

# Alpaca
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_PAPER=true

# Charles Schwab
SCHWAB_APP_KEY=
SCHWAB_APP_SECRET=

# tastytrade
TASTYTRADE_USERNAME=
TASTYTRADE_PASSWORD=

# Interactive Brokers (requires TWS / Gateway running)
IBKR_ACCOUNT_ID=
IBKR_HOST=127.0.0.1
IBKR_PORT=7497

# Tradovate (CME futures)
TRADOVATE_API_KEY=
TRADOVATE_USERNAME=

# NinjaTrader
NINJATRADER_LICENSE_KEY=

# News API keys (optional — enable sources when configured)
FINNHUB_API_KEY=
BENZINGA_API_KEY=
POLYGON_API_KEY=
FMP_API_KEY=
NEWSAPI_KEY=
MARKETAUX_API_KEY=
ALPHA_VANTAGE_KEY=
FRED_API_KEY=
EIA_API_KEY=

# LLM sentiment explanations (optional — rule engine handles most items)
ANTHROPIC_API_KEY=
