# Application
APP_ENV=development
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# TimescaleDB / Postgres
# docker compose up -d  →  postgresql://trading:trading@localhost:5432/trading_ai
DATABASE_URL=postgresql://trading:trading@localhost:5432/trading_ai
# Remote Render: Internal Database URL on web/worker (fromDatabase in render.yaml)
# External/local Mac: ?sslmode=require — certifi CA via pg_connect.py
# PGSSLMODE=require
# DATABASE_CONNECT_TIMEOUT=30

# Data sources
MARKET_DATA_PROVIDER=
DATA_STALE_MINUTES=15
INFLUXDB_URL=
INFLUXDB_TOKEN=
INFLUXDB_ORG=
INFLUXDB_BUCKET=

# Risk limits
MAX_DAILY_LOSS_PCT=2.0
MAX_DRAWDOWN_PCT=10.0
MAX_POSITIONS=3
DEFAULT_RISK_PER_TRADE_PCT=0.5

# Model / validation
MODEL_DIR=./models
PRODUCTION_MODEL_ID=lightgbm_production
RETRAIN_SCHEDULE_DAYS=1
MIN_PATTERN_SAMPLE_SIZE=300
HARMONIC_RATIO_TOLERANCE_PCT=3.0
ELLIOTT_CONFIDENCE_THRESHOLD=0.60
GANN_RESEARCH_ONLY=true

# LLM — Anthropic only (never used for trade execution)
LLM_ENABLED=false
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_MAX_TOKENS=350

# Polygon backfill (run once before replay)
# CSV-only (recommended while downloading — no remote DB stalls):
#   python scripts/backfill_polygon.py --skip-db --timeframe 1m --start 2025-01-01 --end 2025-12-31 --chunk-days 10
#   python scripts/backfill_polygon.py --sync-from-storage --status
#   python scripts/backfill_polygon.py --futures-only --start 2024-01-01 --end 2025-12-31 --chunk-days 10
# DB + optional CSV: omit --skip-db
# BACKFILL_START=2024-01-01
# BACKFILL_END=2025-12-31
# BACKFILL_TIMEFRAME=1m
# BACKFILL_SKIP_DB=false
# BACKFILL_EXPORT_CSV=false
# BACKFILL_CHUNK_DAYS=10
# WATCHER_DATA_PATH=data/ohlcv
POLYGON_API_KEY=

# Paper trading (keep true until you are ready for Coinbase live)
PAPER_TRADING_ENABLED=true
SIGNAL_LOG_DIR=./logs/signals

# ── Coinbase Advanced Trade (crypto) ─────────────────────────
# Create CDP API key: https://docs.cdp.coinbase.com/advanced-trade/docs/getting-started
# Permissions: View + Trade only (no Transfer/Receive)
COINBASE_API_KEY=
COINBASE_API_SECRET=
# Or path to downloaded cdp_api_key.json:
# COINBASE_API_KEY_FILE=
# Primary portfolio UUID (optional — uses default portfolio if empty)
COINBASE_PORTFOLIO_ID=
# Live orders: requires PAPER_TRADING_ENABLED=false AND coinbase in ENABLED_BROKERS
COINBASE_LIVE_ENABLED=false
COINBASE_MAX_ORDER_USD=50

# ── OANDA v20 (forex) ───────────────────────────────────────
# API token from OANDA account → Manage API Access
# ONDA_API_KEY is accepted as an alias for OANDA_API_KEY
OANDA_API_KEY=
# ONDA_API_KEY=
OANDA_ACCOUNT_ID=
# Practice (fxPractice) vs live (fxTrade)
OANDA_PRACTICE=true
# Live orders: PAPER_TRADING_ENABLED=false AND oanda in ENABLED_BROKERS
OANDA_LIVE_ENABLED=false
OANDA_DEFAULT_UNITS=1000
OANDA_MAX_UNITS=10000

ENABLED_BROKERS=paper

# ── Risk engine (Coinbase primary account guardrails) ────────
RISK_ACCOUNT_CAP_USD=500
RISK_MAX_DAILY_LOSS_USD=30
RISK_MAX_ORDER_NOTIONAL_USD=50
RISK_MAX_OPEN_POSITIONS=2

# News intelligence
NEWS_ENABLED=true
NEWS_POLLING_INTERVAL_SECONDS=60
NEWS_LOAD_DEFAULT_CALENDAR=false
