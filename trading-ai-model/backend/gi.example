# Application
APP_ENV=development
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# TimescaleDB / Postgres
# docker compose up -d  →  postgresql://trading:trading@localhost:5432/trading_ai
DATABASE_URL=postgresql://trading:trading@localhost:5432/trading_ai
# Remote Render: append ?sslmode=require — sslrootcert uses certifi automatically

# Polygon backfill — futures use contract codes (MESH25, …) for BACKFILL year
# BACKFILL_FUTURES_YEAR=2025

# Data sources
MARKET_DATA_PROVIDER=
DATA_STALE_MINUTES=15
INFLUXDB_URL=
INFLUXDB_TOKEN=
INFLUXDB_ORG=
INFLUXDB_BUCKET=

# Risk limits
MAX_DAILY_LOSS_PCT=2.0
MAX_DRAWDOWN_PCT=10.0
MAX_POSITIONS=3
DEFAULT_RISK_PER_TRADE_PCT=0.5

# Model / validation
MODEL_DIR=./models
PRODUCTION_MODEL_ID=lightgbm_production
RETRAIN_SCHEDULE_DAYS=1
MIN_PATTERN_SAMPLE_SIZE=300
HARMONIC_RATIO_TOLERANCE_PCT=3.0
ELLIOTT_CONFIDENCE_THRESHOLD=0.60
GANN_RESEARCH_ONLY=true

# LLM — Anthropic only (never used for trade execution)
LLM_ENABLED=false
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_MAX_TOKENS=350

# Polygon backfill (run once before replay): python scripts/backfill_polygon.py --export-csv
# BACKFILL_START=2025-01-01
# BACKFILL_END=2025-12-31
# BACKFILL_TIMEFRAME=1m
# BACKFILL_EXPORT_CSV=true
POLYGON_API_KEY=

# Paper trading (keep true until you are ready for Coinbase live)
PAPER_TRADING_ENABLED=true
SIGNAL_LOG_DIR=./logs/signals

# ── Coinbase Advanced Trade (crypto) ─────────────────────────
# Create CDP API key: https://docs.cdp.coinbase.com/advanced-trade/docs/getting-started
# Permissions: View + Trade only (no Transfer/Receive)
COINBASE_API_KEY=
COINBASE_API_SECRET=
# Or path to downloaded cdp_api_key.json:
# COINBASE_API_KEY_FILE=
# Primary portfolio UUID (optional — uses default portfolio if empty)
COINBASE_PORTFOLIO_ID=
# Live orders: requires PAPER_TRADING_ENABLED=false AND coinbase in ENABLED_BROKERS
COINBASE_LIVE_ENABLED=false
COINBASE_MAX_ORDER_USD=50
ENABLED_BROKERS=paper

# ── Risk engine (Coinbase primary account guardrails) ────────
RISK_ACCOUNT_CAP_USD=500
RISK_MAX_DAILY_LOSS_USD=30
RISK_MAX_ORDER_NOTIONAL_USD=50
RISK_MAX_OPEN_POSITIONS=2

# News intelligence
NEWS_ENABLED=true
NEWS_POLLING_INTERVAL_SECONDS=60
NEWS_LOAD_DEFAULT_CALENDAR=false
