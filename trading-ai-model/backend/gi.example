# Application
APP_ENV=development
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# TimescaleDB / Postgres
# docker compose up -d  →  postgresql://trading:trading@localhost:5432/trading_ai
DATABASE_URL=postgresql://trading:trading@localhost:5432/trading_ai

# Data sources
MARKET_DATA_PROVIDER=
DATA_STALE_MINUTES=15
INFLUXDB_URL=
INFLUXDB_TOKEN=
INFLUXDB_ORG=
INFLUXDB_BUCKET=

# Risk limits
MAX_DAILY_LOSS_PCT=2.0
MAX_DRAWDOWN_PCT=10.0
MAX_POSITIONS=3
DEFAULT_RISK_PER_TRADE_PCT=0.5

# Model / validation
MODEL_DIR=./models
PRODUCTION_MODEL_ID=lightgbm_production
RETRAIN_SCHEDULE_DAYS=1
MIN_PATTERN_SAMPLE_SIZE=300
HARMONIC_RATIO_TOLERANCE_PCT=3.0
ELLIOTT_CONFIDENCE_THRESHOLD=0.60
GANN_RESEARCH_ONLY=true

# LLM — Anthropic only (never used for trade execution)
LLM_ENABLED=false
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_MAX_TOKENS=350

# Paper trading
PAPER_TRADING_ENABLED=true
SIGNAL_LOG_DIR=./logs/signals

# News intelligence
NEWS_ENABLED=true
NEWS_POLLING_INTERVAL_SECONDS=60
NEWS_LOAD_DEFAULT_CALENDAR=false
